{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api",
        "region": "europe-west1"
      }
    ]
  },
  "functions": [
    {
      "source": ".",
      "codebase": "onklv-app",
      "ignore": [
        "node_modules",
        ".git",
        "public",
        "**/.env",
        ".tmp"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
